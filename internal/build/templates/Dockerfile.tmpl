# Generated by desktopus — DO NOT EDIT
# Desktop: {{ .Name }}

FROM {{ .BaseImage }}

# ============================================
# Ansible provisioning
# ============================================
USER root

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ansible \
      python3-apt \
{{- range .SystemPackages }}
      {{ . }} \
{{- end }}
    && rm -rf /var/lib/apt/lists/*

COPY modules/ /tmp/desktopus-build/modules/
COPY playbook.yml /tmp/desktopus-build/playbook.yml
COPY ansible.cfg /tmp/desktopus-build/ansible.cfg

RUN cd /tmp/desktopus-build && \
    ANSIBLE_CONFIG=/tmp/desktopus-build/ansible.cfg \
    ansible-playbook playbook.yml --connection=local \
{{- if gt .AnsibleVerbosity 0 }}
    -{{ repeat .AnsibleVerbosity "v" }} \
{{- end }}
    && apt-get purge -y ansible && \
    apt-get autoremove -y && \
    rm -rf /tmp/desktopus-build /var/lib/apt/lists/* /root/.ansible

{{- if .PostRunScripts }}

# ============================================
# Post-run scripts (s6 custom-cont-init.d)
# ============================================
COPY postrun/ /custom-cont-init.d/
RUN chmod +x /custom-cont-init.d/*
{{- end }}

{{- if .RuntimeFiles }}

# ============================================
# Runtime files (envsubst at startup)
# ============================================
COPY runtime-files/ /tmp/desktopus-runtime-files/
COPY 99-desktopus-files.sh /custom-cont-init.d/99-desktopus-files.sh
RUN chmod +x /custom-cont-init.d/99-desktopus-files.sh
{{- end }}

# ============================================
# Labels
# ============================================
LABEL org.desktopus.name="{{ .Name }}"
LABEL org.desktopus.description="{{ .Description }}"

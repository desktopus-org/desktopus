# Generated by desktopus — DO NOT EDIT
# Desktop: {{ .Name }}

FROM {{ .BaseImage }}
{{- if .CreateUser }}

# ============================================
# Create desktop user
# ============================================
RUN useradd -m -d {{ .Home }} -s /bin/bash {{ .User }}

# ============================================
# Patch s6 services and desktop session launchers
# to run as {{ .User }} instead of the built-in abc user.
# Uses word-boundary replacement so every reference is covered:
# s6-setuidgid, chown/lsiown ownership, pgrep -u, id -u/G,
# group ownership (root:abc), xdg-runtime paths, etc.
# ============================================
RUN find /etc/s6-overlay/s6-rc.d/ -type f -name "run" \
      -exec sed -i 's/\babc\b/{{ .User }}/g' {} + && \
    find /defaults/ -maxdepth 1 -name "startwm*.sh" \
      -exec sed -i 's/\babc\b/{{ .User }}/g' {} +
{{- end }}

# ============================================
# Ansible provisioning
# ============================================
USER root

{{- if or (eq .OS "ubuntu") (eq .OS "debian") }}

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ansible \
      python3-apt \
{{- range .SystemPackages }}
      {{ . }} \
{{- end }}
    && rm -rf /var/lib/apt/lists/*
{{- else if or (eq .OS "fedora") (eq .OS "el") }}

RUN dnf install -y \
      ansible \
      python3-dnf \
{{- range .SystemPackages }}
      {{ . }} \
{{- end }}
    && dnf clean all
{{- else if eq .OS "arch" }}

RUN pacman -Sy --noconfirm \
      ansible \
      python \
{{- range .SystemPackages }}
      {{ . }} \
{{- end }}
    && pacman -Scc --noconfirm
{{- else if eq .OS "alpine" }}

RUN apk add --no-cache \
      ansible \
      python3 \
{{- range .SystemPackages }}
      {{ . }} \
{{- end }}
    && true
{{- end }}

COPY modules/ /tmp/desktopus-build/modules/
COPY playbook.yml /tmp/desktopus-build/playbook.yml
COPY ansible.cfg /tmp/desktopus-build/ansible.cfg

{{- if or (eq .OS "ubuntu") (eq .OS "debian") }}

RUN cd /tmp/desktopus-build && \
    ANSIBLE_CONFIG=/tmp/desktopus-build/ansible.cfg \
    ansible-playbook playbook.yml --connection=local \
{{- if gt .AnsibleVerbosity 0 }}
    -{{ repeat .AnsibleVerbosity "v" }} \
{{- end }}
    && apt-get purge -y ansible && \
    apt-get autoremove -y && \
    rm -rf /tmp/desktopus-build /var/lib/apt/lists/* /root/.ansible
{{- else if or (eq .OS "fedora") (eq .OS "el") }}

RUN cd /tmp/desktopus-build && \
    ANSIBLE_CONFIG=/tmp/desktopus-build/ansible.cfg \
    ansible-playbook playbook.yml --connection=local \
{{- if gt .AnsibleVerbosity 0 }}
    -{{ repeat .AnsibleVerbosity "v" }} \
{{- end }}
    && dnf remove -y ansible && \
    dnf clean all && \
    rm -rf /tmp/desktopus-build /root/.ansible
{{- else if eq .OS "arch" }}

RUN cd /tmp/desktopus-build && \
    ANSIBLE_CONFIG=/tmp/desktopus-build/ansible.cfg \
    ansible-playbook playbook.yml --connection=local \
{{- if gt .AnsibleVerbosity 0 }}
    -{{ repeat .AnsibleVerbosity "v" }} \
{{- end }}
    && pacman -Rns --noconfirm ansible && \
    pacman -Scc --noconfirm && \
    rm -rf /tmp/desktopus-build /root/.ansible
{{- else if eq .OS "alpine" }}

RUN cd /tmp/desktopus-build && \
    ANSIBLE_CONFIG=/tmp/desktopus-build/ansible.cfg \
    ansible-playbook playbook.yml --connection=local \
{{- if gt .AnsibleVerbosity 0 }}
    -{{ repeat .AnsibleVerbosity "v" }} \
{{- end }}
    && apk del ansible && \
    rm -rf /tmp/desktopus-build /root/.ansible
{{- end }}

{{- if .PostRunScripts }}

# ============================================
# Post-run scripts (s6 custom-cont-init.d)
# ============================================
COPY postrun/ /custom-cont-init.d/
RUN chmod +x /custom-cont-init.d/*
{{- end }}

{{- if .RuntimeFiles }}

# ============================================
# Runtime files (envsubst at startup)
# ============================================
COPY runtime-files/ /tmp/desktopus-runtime-files/
COPY 99-desktopus-files.sh /custom-cont-init.d/99-desktopus-files.sh
RUN chmod +x /custom-cont-init.d/99-desktopus-files.sh
{{- end }}

# ============================================
# Labels
# ============================================
LABEL org.desktopus.name="{{ .Name }}"
LABEL org.desktopus.description="{{ .Description }}"
